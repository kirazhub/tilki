# Tilki Kripto Ajanı - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve düzenleyin

# USD/TL Başlangıç Kuru (otomatik güncellenir)
USD_TL_KUR=34.0

# Başlangıç Sermayesi
BASLANGIC_SERMAYE_USD=3000.0
BASLANGIC_SERMAYE_TL=134000.0

# Dashboard Port
DASHBOARD_PORT=8501

# Log Seviyesi (DEBUG, INFO, WARNING, ERROR)
LOG_SEVIYESI=INFO

# CoinGecko API İstek Aralığı (saniye, ücretsiz limit için)
COINGECKO_ARALIK=1.2

# Yenileme Süresi (saniye)
YENILEME_SURESI=30
